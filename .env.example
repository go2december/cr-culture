# CR-Culture Environment Variables

# Database
# Replace <YOUR_PASSWORD> with the password for your local dev DB.
DATABASE_URI=mongodb://admin:<YOUR_PASSWORD>@localhost:27017/crculture?authSource=admin

# Payload CMS
PAYLOAD_SECRET=<YOUR_PAYLOAD_SECRET>

# Server
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# Analytics (Umami)
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=<YOUR_UMAMI_WEBSITE_ID>
NEXT_PUBLIC_UMAMI_SHARE_URL=https://cloud.umami.is/share/<YOUR_UMAMI_SHARE_ID>