# CR-Culture Environment Variables

# Database
# Host-side development/build uses localhost.
# docker-compose.yml overrides the app container to use the `mongodb` service hostname.
DATABASE_URI=mongodb://admin:password123@localhost:27017/crculture?authSource=admin

# Payload CMS
PAYLOAD_SECRET=cr-culture-super-secret-key-2026-change-in-production

# Server
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# Analytics (Umami)
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=1c0838f4-0928-489c-b74c-3bbe598f2bf7
NEXT_PUBLIC_UMAMI_SHARE_URL=https://cloud.umami.is/share/Bz6LueNjjbvdJJ69