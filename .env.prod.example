# =========================================================================
# CR-Culture Production Environment Configuration (Example)
# Copy this file to '.env.prod' on your production server:
# cp .env.prod.example .env.prod
# =========================================================================

# Next.js Port on the host machine (default: 3000)
PORT=3000
HOSTNAME=0.0.0.0

# Next.js production server public URL
NEXT_PUBLIC_SERVER_URL=https://cr-culture.com

# Payload CMS configuration
PAYLOAD_SECRET=your_long_secure_random_production_secret_key_here

# MongoDB root user credentials
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=choose_a_strong_password_for_production
MONGO_DB_NAME=crculture

# Analytics (Umami)
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=1c0838f4-0928-489c-b74c-3bbe598f2bf7
NEXT_PUBLIC_UMAMI_SHARE_URL=https://cloud.umami.is/share/Bz6LueNjjbvdJJ69
